---
import BaseLayout from "../layouts/BaseLayout.astro";
import MiniTerminal from "../components/MiniTerminal";
---
<BaseLayout title="Andreas Roos" current="/">
    <div class="max-w-4xl mx-auto px-4 flex flex-col items-center justify-center min-h-[50vh] text-center">

        <!-- ASCII Art Name with pixelated glow -->
        <div class="relative mb-8 opacity-0 animate-fade-up">
            <!-- Prompt -->
            <p class="font-mono text-xs text-zinc-500 mb-3 text-left">
                <span class="text-ctp-green">$</span> whoami
            </p>

            <!-- Pixelated glow blobs -->
            <div class="absolute inset-[-40%] -z-10 opacity-30" style="filter: url(#pixel)">
                <div class="relative w-full h-full blur-2xl">
                    <div class="absolute inset-0 bg-[#3d2e54]/35 rounded-full animate-blob"></div>
                    <div class="absolute inset-0 bg-[#54303d]/30 rounded-full animate-blob" style="animation-delay: 1.6s"></div>
                    <div class="absolute inset-0 bg-[#2e3d54]/25 rounded-full animate-blob" style="animation-delay: 0.9s"></div>
                </div>
            </div>

            <pre class="font-mono text-[8px] sm:text-xs md:text-sm ascii-art text-white ascii-glow select-none" set:html={`‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ`} />
        </div>

        <!-- Tagline -->
        <p class="font-mono text-sm text-zinc-600 mb-10 opacity-0 animate-fade-up stagger-1">
            backend ¬∑ android ¬∑ kotlin // stockholm
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-12 opacity-0 animate-fade-up stagger-3">
            <a href="/projects"
               class="group px-5 py-2.5 rounded-lg bg-white/[0.03] border border-zinc-800 text-sm font-medium text-white
                      hover:bg-white/[0.08] hover:border-zinc-600 transition-all duration-300">
                <span class="font-mono text-ctp-blue/70 mr-1.5 group-hover:text-ctp-blue transition-colors">$</span>
                ls projects/
            </a>
            <a href="/contact"
               class="group px-5 py-2.5 rounded-lg bg-white/[0.03] border border-zinc-800 text-sm font-medium text-zinc-400
                      hover:bg-white/[0.08] hover:border-zinc-600 hover:text-white transition-all duration-300">
                <span class="font-mono text-ctp-peach/70 mr-1.5 group-hover:text-ctp-peach transition-colors">$</span>
                cat contact.txt
            </a>
        </div>

        <!-- Interactive Mini Terminal -->
        <div class="w-full max-w-md opacity-0 animate-fade-up stagger-4">
            <MiniTerminal client:idle />
        </div>
    </div>
</BaseLayout>
