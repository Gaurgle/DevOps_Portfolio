---
import BaseLayout from "../layouts/BaseLayout.astro";
import MiniTerminal from "../components/MiniTerminal";
import AboutSection from "../components/sections/AboutSection.astro";
import JourneySection from "../components/sections/JourneySection.astro";
import ContactPanel from "../components/sections/ContactPanel.astro";
import FeaturedShowcase from "../components/sections/FeaturedShowcase.astro";
import TechMarquee from "../components/TechMarquee.tsx";
import ProjectsGrid from "../components/ProjectsGrid.tsx";
---
<BaseLayout title="Andreas Roos" current="/" revealFooter>
    <ContactPanel slot="reveal-panel" />

    <!-- ================= HERO ================= -->
    <!-- Negative top margin cancels the layout's header padding, so the hero
         is pinned and truly centered at scroll 0 (no tiny settle-scroll) -->
    <!-- Pin holds until the ROOS dissolve completes (~0.63vh of scrub) -->
    <section id="home" data-section="home" data-snap data-pin="0.75" data-pin-mobile
             data-cmd="whoami" data-cmd-color="#a6e3a1"
             class="relative -mt-[80px] md:-mt-[100px]">
        <!-- Full first screen on mobile (svh: stable under the URL bar) so
             the next chapter's mark never peeks below the hero. The hero pins
             on mobile too (data-pin-mobile), so the explosion plays out while
             the screen holds still instead of during the scroll-away. -->
        <!-- pb lifts the centered content ~4.5vh above geometric center:
             optically balanced instead of reading slightly low -->
        <div data-hero-scrub class="pin-viewport relative min-h-[100svh] md:min-h-[calc(100vh-120px)] flex flex-col items-center justify-center pb-[9vh]">
        <div class="hero-boom max-w-4xl mx-auto px-4 flex flex-col items-center justify-center text-center">

            <!-- ASCII Art Name with pixelated glow (extra bottom margin keeps
                 the hover sketch underline clear of the tagline) -->
            <div class="relative mb-16 opacity-0 animate-fade-up">
                <!-- Soft color glow blobs (desktop only: three large blurred
                     layers inside the scaling explosion kill phone GPUs) -->
                <div class="hidden md:block absolute inset-[-40%] -z-10 opacity-30">
                    <div class="relative w-full h-full blur-2xl">
                        <div class="absolute inset-0 bg-[#3d2e54]/35 rounded-full" style="transform: translate(8%, -6%) scale(1.05)"></div>
                        <div class="absolute inset-0 bg-[#54303d]/30 rounded-full" style="transform: translate(-7%, 5%) scale(0.95)"></div>
                        <div class="absolute inset-0 bg-[#2e3d54]/25 rounded-full" style="transform: translate(3%, 6%)"></div>
                    </div>
                </div>

                <pre data-roos class="font-mono text-xs sm:text-base md:text-xl lg:text-2xl ascii-art text-white ascii-glow select-none cursor-pointer" set:html={`
██████╗  ██████╗  ██████╗ ███████╗
██╔══██╗██╔═══██╗██╔═══██╗██╔════╝
██████╔╝██║   ██║██║   ██║███████╗
██╔══██╗██║   ██║██║   ██║╚════██║
██║  ██║╚██████╔╝╚██████╔╝███████║
╚═╝  ╚═╝ ╚═════╝  ╚═════╝ ╚══════╝
`} />
            </div>

        </div>

        <!-- Terminal path: outside the explosion - it only fades, early -->
        <p class="hero-path font-mono text-sm text-zinc-400 mt-4">
            ~/portfolio <span class="animate-pulse text-ctp-green">_</span>
        </p>

        </div>
    </section>

    <!-- ================= ABOUT ================= -->
    <AboutSection />

    <!-- ================= JOURNEY (pinned card stack) ================= -->
    <JourneySection />

    <!-- ================= TECH MARQUEE ================= -->
    <!-- Unpinned: it reads as a palate-cleanser divider between the two big
         chapters, not a held moment - and every other section already pins. -->
    <section class="relative py-8">
        <TechMarquee client:idle />
    </section>

    <!-- ================= PROJECTS ================= -->
    <!-- Desktop tail: the ls listing is short, and without this cushion it
         would rest inside the contact reveal band (the magnet would pull
         the page away while the visitor reads the list) -->
    <section id="projects" data-section="projects" data-snap
             data-cmd="ls projects/" data-cmd-color="#89b4fa"
             class="relative max-w-6xl mx-auto px-4 pb-16 md:pb-[45vh]">
        <!-- Flagship projects: pinned horizontal filmstrip; the 03 chapter
             mark lives inside the strip's viewport and gets pushed out by
             the first card -->
        <FeaturedShowcase />

        <!-- ...then the rest, flowing freely: after the pinned filmstrip a
             plain-scrolling grid is the contrast that makes the pins land -->
        <div class="relative z-10 mt-10 md:mt-[6vh]">
            <h3 class="font-bold uppercase tracking-[0.3em] text-xl md:text-2xl text-white/80 select-none mb-10">
                <span class="text-ctp-blue font-mono mr-2">//</span>more projects
            </h3>
            <ProjectsGrid client:load />
        </div>
    </section>

    <!-- Contact anchor sentinel: scrolling here reveals the fixed panel below the page -->
    <div id="contact" class="h-px"></div>

    <!-- Secret terminal: summoned by clicking ROOS -->
    <div id="secret-terminal" class="hidden fixed bottom-14 right-4 z-50 w-full max-w-md">
        <MiniTerminal client:idle />
    </div>
</BaseLayout>

<script>
    document.addEventListener("astro:page-load", () => {
        // Secret: clicking ROOS summons the terminal
        const roos = document.querySelector("[data-roos]");
        const secret = document.getElementById("secret-terminal");
        if (roos && secret) {
            roos.addEventListener("click", () => secret.classList.toggle("hidden"));
        }
    });
</script>
