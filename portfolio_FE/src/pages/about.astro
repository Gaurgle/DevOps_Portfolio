---
import BaseLayout from "../layouts/BaseLayout.astro";
import TechStack from "../components/TechStack.tsx";
---

<BaseLayout title="About" current="/about">
    <div class="max-w-4xl mx-auto px-4 space-y-6">

        <!-- Page header -->
        <div class="opacity-0 animate-fade-up">
            <p class="font-mono text-sm text-zinc-400 mb-6">
                <span class="text-ctp-mauve">$</span> cat about.txt
            </p>
        </div>

        <!-- Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Who I Am -->
            <div class="terminal-card opacity-0 animate-fade-up stagger-1">
                <div class="terminal-bar">
                    <span class="terminal-dot bg-ctp-red/80"></span>
                    <span class="terminal-dot bg-ctp-yellow/80"></span>
                    <span class="terminal-dot bg-ctp-green/80"></span>
                    <span class="font-mono text-xs text-zinc-400 ml-2">who.txt</span>
                </div>
                <div class="p-6">
                    <h2 class="text-lg font-semibold mb-3">Who I Am</h2>
                    <p class="text-sm text-zinc-300 leading-relaxed">
                        Backend and Android developer building APIs, services, and apps with
                        <span class="text-zinc-300">Kotlin</span>,
                        <span class="text-zinc-300">Java</span>, and
                        <span class="text-zinc-300">Spring Boot</span>/<span class="text-zinc-300">Ktor</span>.
                        Hands-on with Bluetooth LE, Jetpack Compose, and full-stack systems.
                        Currently studying at
                        <span class="text-zinc-300">Nackademin</span> and interning at
                        <span class="text-zinc-300">Sigma Connectivity</span>.
                    </p>
                </div>
            </div>

            <!-- Background -->
            <div class="terminal-card opacity-0 animate-fade-up stagger-2">
                <div class="terminal-bar">
                    <span class="terminal-dot bg-ctp-red/80"></span>
                    <span class="terminal-dot bg-ctp-yellow/80"></span>
                    <span class="terminal-dot bg-ctp-green/80"></span>
                    <span class="font-mono text-xs text-zinc-400 ml-2">background.txt</span>
                </div>
                <div class="p-6">
                    <h2 class="text-lg font-semibold mb-3">Background</h2>
                    <p class="text-sm text-zinc-300 leading-relaxed">
                        Before tech: 10+ years in the music industry as a drummer, producer,
                        mixing engineer and live technician. Produced and worked with
                        <span class="text-zinc-300">Liam Payne</span>,
                        <span class="text-zinc-300">Benjamin Ingrosso</span> (incl. Eurovision),
                        <span class="text-zinc-300">Loreen</span>,
                        <span class="text-zinc-300">Astrid S</span>,
                        <span class="text-zinc-300">Veronica Maggio</span>, and
                        <span class="text-zinc-300">Vault Boy</span>.
                        That's where the habit of solving problems under pressure comes from &mdash;
                        now channeling it into code.
                    </p>
                </div>
            </div>

            <!-- As a Developer — full width -->
            <div class="terminal-card md:col-span-2 opacity-0 animate-fade-up stagger-3">
                <div class="terminal-bar">
                    <span class="terminal-dot bg-ctp-red/80"></span>
                    <span class="terminal-dot bg-ctp-yellow/80"></span>
                    <span class="terminal-dot bg-ctp-green/80"></span>
                    <span class="font-mono text-xs text-zinc-400 ml-2">developer.txt</span>
                </div>
                <div class="p-6">
                    <h2 class="text-lg font-semibold mb-3">As a Developer</h2>
                    <p class="text-sm text-zinc-300 leading-relaxed mb-3">
                        Backend is where I feel most at home &mdash;
                        <span class="text-zinc-300">Spring Boot</span> with
                        <span class="text-zinc-300">Kotlin</span>,
                        <span class="text-zinc-300">Docker</span>,
                        <span class="text-zinc-300">PostgreSQL</span>.
                        Building things that run reliably and hold up at scale.
                        I care about clean architecture, proper testing, and understanding
                        what's happening under the hood rather than just above it.
                    </p>
                    <p class="text-sm text-zinc-300 leading-relaxed">
                        I'm also deep into
                        <span class="text-zinc-300">Android</span> development.
                        Currently building a BLE testing tool in Kotlin with
                        <span class="text-zinc-300">Jetpack Compose</span> &mdash;
                        it connects to Bluetooth Low Energy devices, digs into GATT services
                        and characteristics, and runs automated test scripts through an
                        embedded Lua engine. Kotlin coroutines, thread-safe operation queuing,
                        and working close to the hardware is the kind of work I find most interesting.
                    </p>
                </div>
            </div>

            <!-- Tech Stack — full width -->
            <div id="stack-card" class="terminal-card md:col-span-2 opacity-0 animate-fade-up stagger-4 !overflow-visible">
                <div class="terminal-bar rounded-t-lg">
                    <span class="terminal-dot bg-ctp-red/80"></span>
                    <span class="terminal-dot bg-ctp-yellow/80"></span>
                    <span class="terminal-dot bg-ctp-green/80"></span>
                    <span class="font-mono text-xs text-zinc-400 ml-2">stack.txt</span>
                </div>
                <div class="p-6">
                    <TechStack client:idle parentId="stack-card" />
                </div>
            </div>

        </div>
    </div>
</BaseLayout>
