---
import CommonHead from "../components/CommonHead.astro";
import "../styles/global.css";
import Banner from "../components/Banner.astro";
import Sidebar from "../components/Sidebar.astro";
import SidebarToggle from "../components/SidebarToggle";
import ParticleBg from "../../public/js/ParticleBg";
import EasterEggs from "../components/EasterEggs";
import Footer from "../components/Footer.astro";

const {title, description, current = "/"} = Astro.props;
const isHome = Astro.url.pathname === "/";
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <CommonHead {title} {description} />
</head>

<body class="font-sans bg-black text-white relative">
<!-- Scroll progress bar (driven by Lenis) -->
<div id="scroll-progress"></div>

<!-- Particle background as a parallax layer -->
<div class="bg-behind pointer-events-none" data-parallax-speed="0.12">
    <ParticleBg client:idle />
</div>

<!-- BANNER -->
<header class="fixed inset-x-0 top-0 z-50 pointer-events-auto">
    <Banner isHome={isHome} />
</header>

<!-- SIDEBAR TOGGLE (outside header to avoid z-50 stacking context trapping the overlay) -->
<SidebarToggle client:load />

<!-- SIDEBAR -->
<Sidebar {current} />

<!-- GRID CONTAINER -->
<div class="relative z-20 min-h-screen md:ml-54 md:pl-54">
    <main class="relative z-10 min-h-screen p-4 md:p-6 pt-[80px] md:pt-[100px] pb-60">
        <div class="hero mb-4">
            <slot name="hero"/>
        </div>
        <slot/>
    </main>
</div>

<!-- Easter eggs (React component for reliable hydration with ClientRouter) -->
<EasterEggs client:load />

<!-- System-status line -->
<Footer />

</body>
</html>

<script>
    import { wireSmoothScroll, initSmoothScroll } from "../lib/smoothScroll";
    // Register lifecycle hooks once; ClientRouter re-fires page-load per navigation.
    wireSmoothScroll();
    // Init immediately if page-load already fired before this module ran (idempotent).
    if (document.readyState !== "loading") initSmoothScroll();
</script>
