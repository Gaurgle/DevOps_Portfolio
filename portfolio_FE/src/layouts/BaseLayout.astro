---
import CommonHead from "../components/CommonHead.astro";
import "../styles/global.css";
import Banner from "../components/Banner.astro";
import Sidebar from "../components/Sidebar.astro";
import SidebarToggle from "../components/SidebarToggle";
import ParticleLayers from "../components/ParticleLayers.astro";
import EasterEggs from "../components/EasterEggs";

// revealFooter: the page content lifts away at the end to expose a fixed
// panel (the contact section on the one-pager) sitting underneath.
const {title, description, current = "/", revealFooter = false} = Astro.props;
const isHome = Astro.url.pathname === "/";
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <CommonHead {title} {description} />
</head>

<body class="font-sans bg-black text-white relative">
<!-- Scroll progress bar (driven by Lenis) -->
<div id="scroll-progress"></div>

<!-- BANNER -->
<header class="fixed inset-x-0 top-0 z-50 pointer-events-auto">
    <Banner isHome={isHome} />
</header>

<!-- Docked section prompt: separate fixed object ABOVE the header bar
     (page content lives in a z-10 stacking context and can never rise over
     the z-50 banner, so this cannot be a sticky element inside a section).
     The scroll spy re-types the active section's command into it. -->
<div id="dock-prompt"
     class="fixed z-[60] top-[26px] left-8 max-w-[11.5rem] overflow-hidden whitespace-nowrap font-mono text-sm text-zinc-300 pointer-events-none select-none hidden md:block">
    <span id="dock-sigil">$</span> <span id="dock-cmd"></span><span id="dock-caret">▍</span>
</div>

<!-- SIDEBAR TOGGLE (outside header to avoid z-50 stacking context trapping the overlay) -->
<SidebarToggle client:load />

<!-- SIDEBAR -->
<Sidebar {current} />

<!-- Fixed panel revealed as the page lifts at the end (one-pager contact) -->
{revealFooter && <slot name="reveal-panel" />}

<!-- GRID CONTAINER -->
<div class:list={["min-h-screen md:ml-54 md:pl-54", revealFooter ? "page-over-panel" : "relative z-20"]}>
    <!-- Static particle background, parallax-driven (inside the stacking
         context so the opaque page background does not hide it) -->
    <ParticleLayers />

    <!-- Warm hue at the bottom edge, teasing the contact panel -->
    {revealFooter && <div id="bottom-hue" aria-hidden="true"></div>}

    <main class="relative z-10 min-h-screen p-4 md:p-6 pt-[80px] md:pt-[100px] pb-60">
        {Astro.slots.has("hero") && (
            <div class="hero mb-4">
                <slot name="hero"/>
            </div>
        )}
        <slot/>
    </main>
</div>

<!-- Easter eggs (React component for reliable hydration with ClientRouter) -->
<EasterEggs client:load />

</body>
</html>

<script>
    import { wireSmoothScroll } from "../lib/smoothScroll";
    // Register lifecycle hooks once; ClientRouter fires astro:page-load on the
    // initial load as well as after every navigation.
    wireSmoothScroll();
</script>
