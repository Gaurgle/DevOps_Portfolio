---
const { current = "/" } = Astro.props;
---

<aside
    id="sidebar"
    aria-hidden="true"
    class="fixed left-0 top-[64px] md:top-[80px]
     z-40 h-[calc(100vh-64px)] md:h-[calc(100vh-80px)]
     w-54 bg-black/70 backdrop-blur supports-[backdrop-filter]:bg-black/80
     border-r border-white/5
     transform transition-transform duration-300
     -translate-x-full md:translate-x-0">

    <nav class="relative h-full p-8 pt-16 md:pt-8">
        <div class="absolute top-0 right-0 w-px h-full bg-white/5"></div>

        <!-- Terminal path -->
        <p class="font-mono text-[10px] text-zinc-600 mb-6 tracking-wide">
            ~/portfolio <span class="animate-pulse text-ctp-green">_</span>
        </p>

        <!-- Links -->
        <div class="space-y-1">
            <a class="group flex items-center gap-2 py-1.5 font-mono text-sm text-zinc-500 hover:text-white transition-colors duration-200"
               href="/">
                <span class="text-zinc-700 group-hover:text-ctp-green transition-colors">&gt;</span> home
            </a>
            <a class="group flex items-center gap-2 py-1.5 font-mono text-sm text-zinc-500 hover:text-white transition-colors duration-200"
               href="/projects">
                <span class="text-zinc-700 group-hover:text-ctp-green transition-colors">&gt;</span> projects
            </a>
            <a class="group flex items-center gap-2 py-1.5 font-mono text-sm text-zinc-500 hover:text-white transition-colors duration-200"
               href="/about">
                <span class="text-zinc-700 group-hover:text-ctp-green transition-colors">&gt;</span> about
            </a>
            <a class="group flex items-center gap-2 py-1.5 font-mono text-sm text-zinc-500 hover:text-white transition-colors duration-200"
               href="/contact">
                <span class="text-zinc-700 group-hover:text-ctp-green transition-colors">&gt;</span> contact
            </a>
        </div>

        <!-- ASCII footer -->
        <div class="absolute bottom-8 left-8 right-8">
            <pre class="font-mono text-[9px] text-zinc-800 leading-relaxed select-none">
┌──────────────┐
│  &copy; 2026 roos │
└──────────────┘</pre>
        </div>
    </nav>
</aside>
