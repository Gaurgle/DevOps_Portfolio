---
/**
 * Journey: the chapter mark (02 JOURNEY + hook) stays on the left of the
 * pinned viewport while the coaster pile builds on the right - vertical
 * scroll lands each milestone card on the previous one with a cascade
 * offset (smoothScroll.ts drives the transforms). On mobile the same pin
 * plays as a vertical deck: cards rise from below and land nearly flush.
 */
import ChapterMark from "./ChapterMark.astro";

const milestones = [
    {
        n: "01",
        cmd: "music",
        color: "text-ctp-green",
        title: "Studio & stage",
        paras: [
            "15+ years in music. Drums and musical direction with Benjamin " +
            "Ingrosso, MIDI and tracks engineering for Loreen, Veronica Maggio " +
            "and Eva Dahlgren.",
            "Mixing credits: Vault Boy, Benjamin Ingrosso, Liam Payne, Astrid S " +
            "and many more. Signed producer at TEN Music Group - these days " +
            "mastering at IMRSV Music.",
        ],
    },
    {
        n: "02",
        cmd: "the pivot",
        color: "text-ctp-blue",
        title: "Then code happened",
        paras: [
            "Took the Java Developer program at Nackademin. Turns out running " +
            "live shows and writing software use the same muscles: " +
            "preparation, redundancy, staying calm when things break.",
        ],
    },
    {
        n: "03",
        cmd: "backend",
        color: "text-ctp-teal",
        title: "The foundation",
        paras: [
            "Kotlin and Java, Spring Boot and Ktor. Backend is my foundation: " +
            "APIs, data models, PostgreSQL - the part of the system that " +
            "simply has to be correct.",
        ],
    },
    {
        n: "04",
        cmd: "android",
        color: "text-ctp-mauve",
        title: "Android development",
        paras: [
            "Kotlin, Jetpack Compose, Clean Architecture. My main focus: " +
            "building apps end to end - UI, state, testing, and the tricky " +
            "seams where software meets real hardware.",
        ],
    },
    {
        n: "05",
        cmd: "ble · le audio",
        color: "text-ctp-pink",
        title: "BLE & LE Audio",
        paras: [
            "Close to the hardware - not all the way down, but close: nRF dev " +
            "kits, radio protocols, GATT, PAC records, Auracast. Wireless " +
            "audio is where my two worlds meet, and it's the niche I'm " +
            "digging into.",
        ],
    },
    {
        n: "06",
        cmd: "how i build",
        color: "text-ctp-peach",
        title: "Products, not just code",
        paras: [
            "What I care about: apps that feel smooth and reliable, look " +
            "modern, and stay fast, safe and robust underneath. I pick the " +
            "tools the problem needs - not the other way around.",
        ],
    },
];
---

<section id="journey" data-section="journey" data-snap
         data-cmd="./journey --walk" data-cmd-color="#94e2d5"
         class="relative">

    <div data-cardstack data-off-x="26" data-off-y="48" class="journey-stack relative z-10">
        <div class="journey-viewport">
            <!-- md:items-start: the mark's numeral tops out level with the
                 first card's top edge instead of floating centered -->
            <div class="relative z-10 w-full flex flex-col md:flex-row items-center md:items-start md:justify-center gap-5 md:gap-[5vw] px-4 md:px-[4vw] py-4 md:py-0">
                <!-- Chapter mark: stays for the whole pinned pile -->
                <div class="shrink-0 text-center md:text-left">
                    <ChapterMark n="02" label="JOURNEY"
                                 line1="From stage to" accent="stack trace" color="#94e2d5"
 />
                </div>

                <!-- The coaster pile -->
                <div class="stack-area">
                    {milestones.map((m, i) => (
                        <div data-stack-card style={`z-index: ${i + 1}`}>
                            <div class="edit-card h-full">
                                <div class="edit-head">
                                    <span class="text-zinc-400">journey/{m.n}.log</span>
                                </div>
                                <div class="edit-body">
                                    <div class={`font-mono text-xs mb-2 ${m.color}`}>{m.n} · {m.cmd}</div>
                                    <h3 class="text-2xl md:text-4xl font-bold leading-[1.05] text-white mb-4 md:mb-6">{m.title}</h3>
                                    <div class="space-y-3">
                                        {m.paras.map((p) => (
                                            <p class="text-sm md:text-base text-zinc-300 leading-relaxed max-w-xl">{p}</p>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>
