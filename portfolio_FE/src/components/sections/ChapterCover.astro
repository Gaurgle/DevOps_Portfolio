---
/**
 * Full-screen chapter cover: the ChapterMark rectangle pinned as a title
 * slide. The following content pulls itself up (negative margin) and scrolls
 * into frame alongside the still-pinned, fully visible cover; when the pin
 * ends, the cover simply scrolls away to reveal the content. The slide
 * swings left/right with the chapter parity.
 */
import ChapterMark from "./ChapterMark.astro";

const { n, label, line1, pre = "", accent, post = ".", color, accentStyle } = Astro.props;
const flipped = parseInt(n, 10) % 2 === 0;
---

<div data-pin="1" data-cover class="relative">
    <div class:list={["pin-viewport relative min-h-[70vh] flex items-center justify-center", flipped ? "md:justify-end md:pr-[7vw]" : "md:justify-start md:pl-[7vw]"]}>
        <div data-cover-content class="will-change-transform">
            <ChapterMark {n} {label} {line1} {pre} {accent} {post} {color} {accentStyle}
                         width="w-[min(40rem,48vw)]" />
        </div>
    </div>
</div>
