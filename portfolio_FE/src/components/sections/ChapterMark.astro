---
/**
 * Chapter mark as one symmetrical rectangle, numeral on top: the number is
 * SVG text stretched to the full rectangle width, with the hook line(s)
 * beneath - all stretched to fill the box exactly, flush on both edges.
 *
 * Each hook line's font-size is fitted to its text length so short lines get
 * bigger glyphs instead of letter-spacing gaps (textLength then only fine-
 * tunes), keeping the letters tight.
 *
 * `width` sizes the whole rectangle; everything inside scales via
 * aspect-ratio, so the mark stays one proportional unit.
 */
const {
    n,
    label,
    line1,
    pre = "",
    accent,
    post = ".",
    color,
    width = "w-[min(28rem,36vw)]",
    // Each section can give its special word its own face.
    accentStyle = "font-family:Georgia,'Times New Roman',serif;font-style:italic",
} = Astro.props;

/** Fit a line: font-size such that the text naturally fills ~720 units.
 *  `slack` shrinks the glyphs a touch for lines that would get cramped. */
function fit(text: string, slack = 1) {
    const fs = Math.min(220, Math.round((760 * slack) / (0.56 * text.length)));
    return { fs, vb: Math.round(fs * 1.1), y: Math.round(fs * 0.9) };
}

const l1 = line1 ? fit(line1) : null;
// The accent line runs a wider face (Ramose + stroke), so give it slack.
const l2 = fit(`${pre}${accent}${post}`, 0.9);
// A single-line hook fills the whole hook area (double height), so the mark
// keeps the same number-to-text proportions as the two-line variant.
const hookAspect = line1 ? "aspect-[720/115]" : "aspect-[720/235]";
---

<div class:list={["chapter-mark inline-block select-none", width]}
     aria-label={`${n} ${label}: ${line1 ?? ""} ${pre}${accent}${post}`}>
    <!-- Numeral: slightly WIDER than the hook lines (optical alignment reads
         better with a small overhang than with exact equal widths) -->
    <svg class="block w-[106%] -ml-[3%] aspect-[720/300]" viewBox="0 0 720 300" preserveAspectRatio="none" aria-hidden="true">
        <text class="cm-num" x="-8" y="290" font-size="400" textLength="736" lengthAdjust="spacingAndGlyphs" fill="#ffffff">{n}</text>
    </svg>

    <!-- Hook: one or two rows, tight letters, flush to the rectangle edges -->
    <div class="mt-[4%] space-y-[3%]">
        {l1 && line1 && (
            <svg class="block w-full aspect-[720/115]" viewBox={`0 0 720 ${l1.vb}`} preserveAspectRatio="none" aria-hidden="true">
                <text x="0" y={l1.y} font-size={l1.fs} textLength="720" lengthAdjust="spacingAndGlyphs">{line1}</text>
            </svg>
        )}
        <svg class:list={["block w-full", hookAspect]} viewBox={`0 0 720 ${l2.vb}`} preserveAspectRatio="none" aria-hidden="true">
            <text x="0" y={l2.y} font-size={l2.fs} textLength="720" lengthAdjust="spacingAndGlyphs">{pre}<tspan
                fill={color} stroke={color} stroke-width="4" paint-order="stroke"
                style={accentStyle}>{accent}</tspan>{post}</text>
        </svg>
    </div>

    <div class="font-mono tracking-[0.35em] text-lg md:text-xl text-white/45 mt-4">{label}</div>
</div>
