---
/**
 * Featured projects as a pinned card pile (desktop): the chapter mark
 * enters centered, the first card flies in and pushes it out, every card
 * lands on the pile, and the finished pile exits left as one object -
 * leaving the MORE PROJECTS arrow (smoothScroll.ts measureShowcases drives
 * all transforms). On mobile the same markup plays as a vertical deck via
 * the engine's cardstack path: cards rise from below and land flush.
 */
import { projects } from "../../data/projects";
import ChapterMark from "./ChapterMark.astro";

const featured = projects
    .filter((p) => p.featured)
    .sort((a, b) => (a.featuredOrder ?? 99) - (b.featuredOrder ?? 99));
const firstImage = (p: (typeof projects)[number]) =>
    Array.isArray(p.image) ? p.image[0] : p.image;

// Accent per card (rgb triplets for the CSS var): green, mauve, blue, peach
const accents = ["166,227,161", "203,166,247", "137,180,250", "250,179,135"];
---

<div data-hscroll data-cardstack data-snap class="hscroll-pin relative">
    <div class="hscroll-viewport">
        <!-- Chapter mark: pinned WITH the strip, centered until the first
             card arrives and pushes it out left -->
        <div class="absolute inset-0 hidden md:flex items-center justify-center z-0">
            <div data-cover-content class="will-change-transform">
                <ChapterMark n="03" label="PROJECTS"
                             pre="Things I've " accent="built" color="#89b4fa"
                             width="w-[min(18rem,84vw)] md:w-[min(34rem,40vw)]" />
            </div>
        </div>

        <!-- Mobile: compact chapter header sharing the pinned screen with
             the deck (the mark is slimmed via .hscroll-pin .chapter-mark) -->
        <div class="md:hidden px-4 pb-5 text-center">
            <ChapterMark n="03" label="PROJECTS"
                         pre="Things I've " accent="built" color="#89b4fa" />
            <h3 class="mt-3 font-bold uppercase tracking-[0.3em] text-sm text-white/80 select-none">
                <span class="text-ctp-blue font-mono mr-2">//</span>featured projects
            </h3>
        </div>

        <!-- Headline: rides in flush with the first card's leading edge, then
             docks centered while the rest of the strip sweeps past (engine) -->
        <h3 data-hscroll-headline
            class="hidden md:block absolute top-[9vh] left-0 w-max font-bold uppercase tracking-[0.3em] text-xl md:text-2xl text-white/80 select-none whitespace-nowrap z-20 will-change-transform">
            <span data-headline-sigil class="text-ctp-blue font-mono mr-2 transition-colors duration-500">//</span>featured projects
        </h3>
        <div data-hscroll-track class="relative z-10 px-4" style={`--deck-n: ${featured.length - 1}`}>
            {featured.map((p, i) => (
                <div class="featured-card" data-spotlight data-stack-card
                     style={`--fc: ${accents[i % accents.length]}; z-index: ${i + 1}`}>
                    <div class="edit-card h-full">
                        <div class="edit-head">
                            <span style={`color: rgb(${accents[i % accents.length]})`}>
                                featured/{String(i + 1).padStart(2, "0")}
                            </span>
                        </div>
                        {firstImage(p) ? (
                            <div class="edit-media">
                                <img src={firstImage(p)} alt={p.projectTitle} loading="lazy"
                                     class="h-full w-full object-contain md:grayscale md:hover:grayscale-0 transition-all duration-500" />
                            </div>
                        ) : (
                            <div class="edit-media flex items-center justify-center font-mono text-xs text-zinc-600">
                                <span><span class="text-ctp-mauve">$</span> ./preview<br />no screenshot yet</span>
                            </div>
                        )}
                        <div class="edit-body">
                            <h3 class="text-2xl md:text-4xl font-bold leading-[1.05] text-white mb-4 md:mb-5">
                                {p.projectTitle}<span style={`color: rgb(${accents[i % accents.length]})`}>.</span>
                            </h3>
                            <div class="edit-cols">
                                <p class="edit-desc">{p.details?.long}</p>
                                <div class="space-y-2.5">
                                    <ul class="space-y-1.5">
                                        {p.details?.highlights.slice(0, 3).map((h) => (
                                            <li>
                                                <span class="mr-1.5" style={`color: rgb(${accents[i % accents.length]})`}>▸</span>{h}
                                            </li>
                                        ))}
                                    </ul>
                                    <p class="text-zinc-500">{p.tags?.join(" · ").toLowerCase()}</p>
                                    {p.link && p.link !== "#" && (
                                        <a href={p.link} target="_blank" rel="noopener noreferrer"
                                           class="inline-block text-zinc-400 hover:text-white transition-colors duration-200">
                                            github &rarr;
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            ))}

        </div>

        <!-- Finale: a huge arrow, detached from the track (engine-driven).
             It rides in behind the last card, docks aligned under the
             headline, and stays while the last card clears out left. -->
        <!-- Centered on the stage; pt matches the viewport's padding-top so
             the arrow shares the pile's vertical frame -->
        <div class="absolute inset-0 hidden md:flex items-center justify-center pt-[10vh] z-10 pointer-events-none">
            <div data-hscroll-arrow class="flex items-center select-none will-change-transform">
                <!-- Massive elbow arrow; the label bends with it: MORE runs
                     along the top shaft, PROJECTS turns and runs down the leg -->
                <svg class="w-[clamp(22rem,42vw,38rem)] h-auto text-ctp-blue drop-shadow-[0_0_40px_rgba(137,180,250,0.5)]"
                     viewBox="0 0 100 100" aria-hidden="true">
                    <!-- The engine scrubs the assembly: outline draws itself
                         (dashoffset), the fill floods, the label stamps in -->
                    <path fill="currentColor" stroke="currentColor" stroke-width="1.2"
                          d="M2,10 H78 V68 H94 L61,99 L28,68 H44 V44 H2 Z" />
                    <!-- Letters are individual tspans: the engine stamps
                         them on one at a time, typewriter-style. PROJECTS
                         translates to y=14.6 so its P's ink top sits level
                         with MORE's cap line (12 rode ~2.5 units high). -->
                    <text x="4" y="38.5" font-size="33" font-weight="800" fill="#0b0b12"
                          textLength="38" lengthAdjust="spacingAndGlyphs"
                          style="font-family: 'Archivo Black', 'Inter', sans-serif;"><tspan>M</tspan><tspan>O</tspan><tspan>R</tspan><tspan>E</tspan></text>
                    <text transform="translate(52,14.6) rotate(90)" x="0" y="0" font-size="30" font-weight="800" fill="#0b0b12"
                          textLength="55" lengthAdjust="spacingAndGlyphs"
                          style="font-family: 'Archivo Black', 'Inter', sans-serif;"><tspan>P</tspan><tspan>R</tspan><tspan>O</tspan><tspan>J</tspan><tspan>E</tspan><tspan>C</tspan><tspan>T</tspan><tspan>S</tspan></text>
                </svg>
            </div>
        </div>
    </div>
</div>
