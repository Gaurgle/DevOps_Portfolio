---
/**
 * Featured projects as a pinned horizontal filmstrip: the section pins while
 * vertical scroll slides the flagship cards sideways (smoothScroll.ts drives
 * the transform), each with detailed copy. The full grid follows with the
 * rest. Vertical stack on mobile.
 */
import { projects } from "../../data/projects";
import ChapterMark from "./ChapterMark.astro";

const featured = projects.filter((p) => p.featured);
const firstImage = (p: (typeof projects)[number]) =>
    Array.isArray(p.image) ? p.image[0] : p.image;

// Accent per card (rgb triplets for the CSS var): green, mauve, blue, peach
const accents = ["166,227,161", "203,166,247", "137,180,250", "250,179,135"];
---

<div data-hscroll data-snap class="hscroll-pin relative">
    <div class="hscroll-viewport">
        <!-- Chapter mark: pinned WITH the strip, centered until the first
             card arrives and pushes it out left -->
        <div class="absolute inset-0 hidden md:flex items-center justify-center z-0">
            <div data-cover-content class="will-change-transform">
                <ChapterMark n="03" label="PROJECTS"
                             pre="Things I've " accent="built" color="#89b4fa"
                             width="w-[min(34rem,40vw)]" />
            </div>
        </div>

        <!-- Headline: rides in flush with the first card's leading edge, then
             docks centered while the rest of the strip sweeps past (engine) -->
        <h3 data-hscroll-headline
            class="absolute top-[16vh] left-0 w-max font-bold uppercase tracking-[0.3em] text-xl md:text-2xl text-white/80 select-none whitespace-nowrap z-20 will-change-transform">
            <span class="text-ctp-blue font-mono mr-2">//</span>featured projects
        </h3>
        <div data-hscroll-track class="relative z-10 px-4">
            {featured.map((p, i) => (
                <div class="featured-card" data-spotlight style={`--fc: ${accents[i % accents.length]}`}>
                    <div class="terminal-card h-full">
                        <div class="terminal-bar">
                            <span class="terminal-dot bg-ctp-red/80"></span>
                            <span class="terminal-dot bg-ctp-yellow/80"></span>
                            <span class="terminal-dot bg-ctp-green/80"></span>
                            <span class="font-mono text-xs text-zinc-300 ml-2">featured/{String(i + 1).padStart(2, "0")}</span>
                            <span class="font-mono text-xs ml-auto mr-1" style={`color: rgb(${accents[i % accents.length]})`}>{p.projectTitle}</span>
                        </div>
                        <div class="md:flex">
            {firstImage(p) && (
                                <div class="md:w-2/5 shrink-0 flex items-center justify-center bg-zinc-900/30 p-3">
                                    <img src={firstImage(p)} alt={p.projectTitle} loading="lazy"
                                         class="max-h-48 md:max-h-[24rem] w-auto max-w-full object-contain grayscale hover:grayscale-0 transition-all duration-500" />
                                </div>
                            )}
                            <div class="p-6 md:p-8 flex-1">
                                <h3 class="font-mono text-xl md:text-2xl font-semibold text-white mb-3">{p.projectTitle}</h3>
                                <p class="text-sm md:text-base text-zinc-300 leading-relaxed mb-4">{p.details?.long}</p>
                                <ul class="space-y-1.5 mb-5">
                                    {p.details?.highlights.map((h) => (
                                        <li class="font-mono text-xs md:text-sm text-zinc-300">
                                            <span class="mr-2" style={`color: rgb(${accents[i % accents.length]})`}>▸</span>{h}
                                        </li>
                                    ))}
                                </ul>
                                <div class="flex flex-wrap gap-1.5 mb-4">
                                    {p.tags?.map((tag) => (
                                        <span class="px-2 py-0.5 text-[10px] font-mono rounded bg-zinc-800/80 text-zinc-400 border border-zinc-800">{tag}</span>
                                    ))}
                                </div>
                                {p.link && p.link !== "#" && (
                                    <a href={p.link} target="_blank" rel="noopener noreferrer"
                                       class="font-mono text-xs text-zinc-400 hover:text-white transition-colors duration-200">
                                        github &rarr;
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            ))}

        </div>

        <!-- Finale: a huge arrow, detached from the track (engine-driven).
             It rides in behind the last card, docks aligned under the
             headline, and stays while the last card clears out left. -->
        <div class="absolute inset-y-0 left-0 hidden md:flex items-center z-10 pointer-events-none">
            <div data-hscroll-arrow class="flex items-center gap-16 select-none will-change-transform">
                <!-- Massive elbow arrow; the label bends with it: MORE runs
                     along the top shaft, PROJECTS turns and runs down the leg -->
                <svg class="w-[clamp(18rem,36vw,32rem)] h-auto text-ctp-blue drop-shadow-[0_0_40px_rgba(137,180,250,0.5)]"
                     viewBox="0 0 100 100" aria-hidden="true">
                    <path fill="currentColor" d="M2,10 H78 V68 H94 L61,99 L28,68 H44 V44 H2 Z" />
                    <text x="4" y="38.5" font-size="33" font-weight="800" fill="#0b0b12"
                          textLength="38" lengthAdjust="spacingAndGlyphs"
                          style="font-family: 'Archivo Black', 'Inter', sans-serif;">MORE</text>
                    <text transform="translate(52,12) rotate(90)" x="0" y="0" font-size="30" font-weight="800" fill="#0b0b12"
                          textLength="55" lengthAdjust="spacingAndGlyphs"
                          style="font-family: 'Archivo Black', 'Inter', sans-serif;">PROJECTS</text>
                </svg>
            </div>
        </div>
    </div>
</div>
