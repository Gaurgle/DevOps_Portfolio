---
/**
 * About: the chapter mark (01 ABOUT + hook) sticks on the right and rides
 * with the story cards flowing past on the left. The tech stack lives in
 * the marquee band further down (TechMarquee).
 */
import ChapterMark from "./ChapterMark.astro";
---

<section id="about" data-section="about" data-snap
         data-cmd="cat about.txt" data-cmd-color="#cba6f7"
         class="relative max-w-6xl mx-auto px-4">

    <div class="md:flex md:flex-row-reverse md:gap-10">
        <!-- Chapter mark: sticky on the right for the whole section -->
        <div class="md:w-[42%] shrink-0 md:sticky md:top-0 md:h-screen flex flex-col justify-center items-center md:items-end md:text-right pt-24 md:pt-0 z-0">
            <ChapterMark n="01" label="ABOUT"
                         line1="Backend. Android." accent="Audio" color="#cba6f7" />
        </div>

        <!-- Story cards on the left, with a small entry hold (little pin) -->
        <!-- Extra tail: about keeps the frame a while before journey arrives -->
        <div data-hold="0.35" class="md:w-[58%] relative z-10 pt-16 pb-8 md:pt-[18vh] md:pb-[30vh]">
            <!-- Big gaps on desktop (each card owns the frame); compact on
                 mobile where there is no focus effect to justify them -->
            <div data-hold-content class="space-y-14 md:space-y-[40vh]">

            <!-- Who I Am -->
            <!-- TODO: add self-portrait image to this card or as a separate card -->
            <div data-reveal data-focus class="rounded-xl backdrop-blur-[3px]" data-rn-card>
                <div class="p-6">
                    <h3 class="text-base md:text-lg font-bold tracking-[0.2em] uppercase text-ctp-mauve mb-3">Who I Am</h3>
                    <p data-word-reveal class="text-base md:text-lg text-zinc-100 leading-relaxed">
                        Backend and Android developer based in
                        <span class="text-white" data-rn="box">Stockholm, Sweden</span>.
                        Building APIs, services, and apps with
                        <span class="text-white" data-rn="underline">Kotlin</span>,
                        <span class="text-white" data-rn="underline">Java</span>, and
                        <span class="text-white" data-rn="underline">Spring Boot</span>/<span class="text-white" data-rn="underline">Ktor</span>.
                        Hands-on with Bluetooth LE, Jetpack Compose, and full-stack systems.
                        Java Developer program at
                        <span class="text-white" data-rn="underline">Nackademin</span> and a
                        BLE/LE Audio internship at
                        <span class="text-white" data-rn="underline">Sigma Connectivity</span> behind me;
                        currently mastering records at
                        <span class="text-white" data-rn="underline">IMRSV Music</span>.
                    </p>
                </div>
            </div>

            <!-- Background -->
            <div data-reveal data-focus class="rounded-xl backdrop-blur-[3px]" data-rn-card>
                <div class="p-6">
                    <h3 class="text-base md:text-lg font-bold tracking-[0.2em] uppercase text-ctp-pink mb-3">Background</h3>
                    <p data-word-reveal class="text-base md:text-lg text-zinc-100 leading-relaxed">
                        15+ years in the music industry - and counting. Drums and musical
                        direction with
                        <span class="text-white" data-rn="underline">Benjamin Ingrosso</span> (incl. Eurovision),
                        MIDI and tracks engineering for
                        <span class="text-white" data-rn="circle">Loreen</span>,
                        <span class="text-white" data-rn="underline">Veronica Maggio</span> and
                        <span class="text-white" data-rn="underline">Eva Dahlgren</span>,
                        mixing credits for
                        <span class="text-white" data-rn="underline">Vault Boy</span>,
                        <span class="text-white" data-rn="underline">Liam Payne</span> and
                        <span class="text-white" data-rn="underline">Astrid S</span>;
                        signed songwriter and producer at
                        <span class="text-white" data-rn="underline">TEN Music Group</span>.
                        That's where the habit of solving problems under pressure comes from,
                        now channeled into code.
                    </p>
                </div>
            </div>

            <!-- As a Developer -->
            <div data-reveal data-focus class="rounded-xl backdrop-blur-[3px]" data-rn-card>
                <div class="p-6">
                    <h3 class="text-base md:text-lg font-bold tracking-[0.2em] uppercase text-ctp-blue mb-3">As a Developer</h3>
                    <p data-word-reveal class="text-base md:text-lg text-zinc-100 leading-relaxed mb-3">
                        My main focus is
                        <span class="text-white" data-rn="circle">Android</span> development in
                        <span class="text-white" data-rn="underline">Kotlin</span> with
                        <span class="text-white" data-rn="underline">Jetpack Compose</span>, building apps end to end
                        and often working close to the hardware. Right now that includes a
                        <span class="text-white" data-rn="underline">Bluetooth LE</span> and
                        <span class="text-white" data-rn="underline">LE Audio</span> testing tool: it connects to
                        devices, digs into GATT services and characteristics, and runs automated
                        test scripts through an embedded
                        <span class="text-white" data-rn="underline">Lua</span> engine. Coroutines, thread-safe
                        operation queuing, and getting predictable behavior out of real hardware
                        is the kind of problem I enjoy most.
                    </p>
                    <p data-word-reveal class="text-base md:text-lg text-zinc-100 leading-relaxed">
                        It sits on a solid backend foundation:
                        <span class="text-white" data-rn="underline">Spring Boot</span> and
                        <span class="text-white" data-rn="underline">Ktor</span> with Kotlin,
                        <span class="text-white" data-rn="underline">Docker</span>, and
                        <span class="text-white" data-rn="underline">PostgreSQL</span>. I like designing clean APIs
                        and services with proper testing, and understanding the whole path from a
                        device on the bench to data in the database, not just one end of it.
                    </p>
                </div>
            </div>

            </div>
        </div>
    </div>
</section>

<script>
    import { annotate, annotationGroup } from "rough-notation";

    // Catppuccin Mocha accents, cycled across the annotations
    const PALETTE = ["#cba6f7", "#89b4fa", "#a6e3a1", "#fab387", "#f5c2e7", "#94e2d5"];

    function paddingFor(type) {
        if (type === "circle") return 5;
        if (type === "box") return 4;
        return 2;
    }

    // Wire one card: build its annotation group, reveal on hover, clear on leave
    function setupCard(card, colorOffset) {
        const els = Array.from(card.querySelectorAll("[data-rn]"));
        if (els.length === 0) return;

        // Build the annotations statically (animate: false). rough-notation just
        // renders the rough strokes; WE drive the draw via stroke-dashoffset so it
        // can play forward on hover and in reverse on leave.
        const annotations = els.map((el, i) => {
            const type = el.dataset.rn || "underline";
            return annotate(el, {
                type,
                color: PALETTE[(colorOffset + i) % PALETTE.length],
                strokeWidth: 1.4,
                padding: paddingFor(type),
                multiline: type === "underline",
                animate: false,
            });
        });

        const group = annotationGroup(annotations);
        group.show(); // create the SVGs once (fully drawn); we hide them via dashoffset below

        const DRAW_MS = 500; // draw-in on hover
        const UNDRAW_MS = 260; // reverse-draw on leave
        const LINGER_MS = 1500; // stay drawn after the cursor leaves
        const STAGGER_MS = 110; // delay between each word

        // One <svg.rough-annotation> per annotated word; stagger by word, not by path
        const words = () => card.querySelectorAll("svg.rough-annotation");

        // Prime each stroke: dash the whole length and start fully retracted (hidden)
        words().forEach((svg) => {
            svg.querySelectorAll("path").forEach((p) => {
                const len = p.getTotalLength();
                p.style.strokeDasharray = String(len);
                p.style.strokeDashoffset = String(len);
            });
        });

        let lingerTimer = 0;

        const drawIn = () => {
            const svgs = words();
            svgs.forEach((svg, i) => {
                const delay = i * STAGGER_MS; // left-to-right
                svg.querySelectorAll("path").forEach((p) => {
                    p.style.transition = `stroke-dashoffset ${DRAW_MS}ms ease ${delay}ms`;
                    p.style.strokeDashoffset = "0";
                });
            });
        };

        const drawOut = () => {
            const svgs = words();
            const last = svgs.length - 1;
            svgs.forEach((svg, i) => {
                const delay = (last - i) * STAGGER_MS; // reverse order, so it rewinds
                svg.querySelectorAll("path").forEach((p) => {
                    const len = p.style.strokeDasharray || String(p.getTotalLength());
                    p.style.transition = `stroke-dashoffset ${UNDRAW_MS}ms ease-in ${delay}ms`;
                    p.style.strokeDashoffset = len;
                });
            });
        };

        card.addEventListener("mouseenter", () => {
            clearTimeout(lingerTimer);
            drawIn();
        });

        card.addEventListener("mouseleave", () => {
            clearTimeout(lingerTimer);
            lingerTimer = window.setTimeout(drawOut, LINGER_MS);
        });
    }

    function setupAnnotations() {
        const cards = Array.from(document.querySelectorAll("[data-rn-card]"));
        // Offset each card's color start so adjacent cards don't open on the same hue
        cards.forEach((card, i) => setupCard(card, i * 2));
    }

    // Run on first load and after every View Transitions navigation
    document.addEventListener("astro:page-load", setupAnnotations);
</script>
